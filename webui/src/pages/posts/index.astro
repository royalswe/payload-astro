---
import type { Media, Post } from '@payload-types'

import Layout from '../../layouts/Layout.astro'
import {
  getCurrentUser,
  getPayloadBaseURL,
  getPostsArchivePage,
} from '../../lib/payload/client'

export const prerender = false

const isPreview = Astro.url.searchParams.get('preview') === 'true'
const payloadServerURL = getPayloadBaseURL()
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page') || 1))

const [archive, currentUser] = await Promise.all([
  getPostsArchivePage({
    depth: 1,
    limit: 12,
    page: currentPage,
    draft: isPreview,
    request: Astro.request,
  }),
  getCurrentUser({ request: Astro.request }),
])

const toPostHref = (slug: string) => {
  const encodedSlug = encodeURIComponent(slug)
  const url = new URL(`/posts/${encodedSlug}`, 'http://localhost')

  if (isPreview) {
    url.searchParams.set('preview', 'true')
  }

  return `${url.pathname}${url.search}`
}

const toArchiveHref = (page: number) => {
  const url = new URL('/posts', 'http://localhost')

  if (page > 1) {
    url.searchParams.set('page', String(page))
  }

  if (isPreview) {
    url.searchParams.set('preview', 'true')
  }

  return `${url.pathname}${url.search}`
}

const getMediaURL = (media: Post['heroImage']) => {
  if (!media || typeof media === 'number') {
    return null
  }

  const typedMedia = media as Media
  const imagePath = typedMedia.sizes?.small?.url || typedMedia.url

  if (!imagePath) {
    return null
  }

  if (imagePath.startsWith('http://') || imagePath.startsWith('https://')) {
    return imagePath
  }

  return `${payloadServerURL}${imagePath}`
}

const getCategoryNames = (post: Post) =>
  (post.categories || [])
    .map((category) => (typeof category === 'object' ? category.title : null))
    .filter((title): title is string => Boolean(title))
---

<Layout
  title="Posts"
  description="Articles from Payload rendered by Astro"
  adminUser={currentUser}
  adminEditURL={`${payloadServerURL}/admin/collections/posts`}
  preview={isPreview}
  payloadServerURL={payloadServerURL}
>
  <section class="header-card">
    <p class="label">Template migrated from Next frontend</p>
    <h1>Posts</h1>
    <p>
      Showing page {archive.page || 1} of {archive.totalPages || 1} ({archive.totalDocs} total posts)
    </p>
  </section>

  <section class="posts-grid">
    {archive.docs.map((post) => {
      const mediaURL = getMediaURL(post.heroImage)
      const categories = getCategoryNames(post)

      return (
        <article class="post-card">
          {mediaURL && <img src={mediaURL} alt={post.title} loading="lazy" />}

          <div class="post-card__content">
            {categories.length > 0 && (
              <p class="post-card__categories">{categories.join(' · ')}</p>
            )}

            <h2>
              <a href={toPostHref(post.slug)}>{post.title}</a>
            </h2>

            <p>{post.meta?.description || 'No summary is set for this post yet.'}</p>
          </div>
        </article>
      )
    })}

    {archive.docs.length === 0 && (
      <article class="post-card post-card--empty">
        <h2>No posts found</h2>
        <p>Create or publish a post in Payload to populate this template.</p>
      </article>
    )}
  </section>

  <nav class="pagination" aria-label="Posts pagination">
    {archive.hasPrevPage && archive.prevPage ? (
      <a href={toArchiveHref(archive.prevPage)}>Previous</a>
    ) : (
      <span class="disabled">Previous</span>
    )}

    <span>
      Page {archive.page || 1} / {archive.totalPages || 1}
    </span>

    {archive.hasNextPage && archive.nextPage ? (
      <a href={toArchiveHref(archive.nextPage)}>Next</a>
    ) : (
      <span class="disabled">Next</span>
    )}
  </nav>
</Layout>

<style>
  .header-card,
  .pagination {
    margin-top: 1.5rem;
    border: 1px solid #dbe5f4;
    border-radius: 1rem;
    padding: 1.25rem;
    background: #ffffffcc;
    box-shadow: 0 10px 30px rgba(16, 36, 61, 0.06);
  }

  .label {
    margin: 0;
    color: #2457a0;
    font-size: 0.85rem;
    font-weight: 600;
  }

  h1 {
    margin: 0.3rem 0 0.6rem;
  }

  .posts-grid {
    margin-top: 1.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .post-card {
    border: 1px solid #dbe5f4;
    border-radius: 1rem;
    background: #ffffffea;
    overflow: hidden;
    box-shadow: 0 6px 18px rgba(16, 36, 61, 0.08);
  }

  .post-card img {
    display: block;
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: #eaf1fb;
  }

  .post-card__content {
    padding: 1rem;
  }

  .post-card__categories {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    color: #386eb9;
    font-weight: 600;
  }

  .post-card h2 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .post-card p {
    margin: 0.75rem 0 0;
    color: #27415f;
  }

  .post-card a {
    color: #1d4f91;
    text-decoration: none;
  }

  .post-card a:hover {
    text-decoration: underline;
  }

  .post-card--empty {
    padding: 1rem;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pagination a,
  .pagination span {
    font-size: 0.95rem;
  }

  .pagination a {
    color: #1f5fb6;
    text-decoration: none;
    font-weight: 600;
  }

  .pagination a:hover {
    text-decoration: underline;
  }

  .disabled {
    color: #7a8aa0;
  }
</style>
