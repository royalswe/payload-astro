{
  "name": "astro-payload-monorepo",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter payload-app --filter webui dev",
    "dev:payload": "cd payload && pnpm dev:webpack",
    "dev:webui": "cd webui && pnpm dev",
    "generate:types": "pnpm --filter payload-app run generate:types"
  }
}